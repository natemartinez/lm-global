# ============================================
# LM Global Ministries — Environment Variables
# ============================================
# Copy this file to .env.development and fill in the values.
# Never commit secrets to version control.

# --- Tech Care Dashboard (Vite) ---
VITE_USE_MOCK_DATA=true
VITE_API_BASE_URL=http://localhost:3001

# --- Cloudflare Pages Functions (wrangler) ---
# Copy to .dev.vars for local development
JWT_SECRET=your-jwt-secret-here
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
ADMIN_SECRET=your-admin-secret-here
RESEND_API_KEY=re_...
BOOKING_NOTIFICATIONS_EMAIL=bookings@example.com
